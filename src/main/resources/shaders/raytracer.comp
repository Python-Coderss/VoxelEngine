    for (int i = 0; i < u_CraftingItemCount; i++) {
        int blockId = floatBitsToInt(craftingItems[i].position.w);
        if (blockId <= 0) continue;
        vec3 pos = craftingItems[i].position.xyz;
        float scale = craftingItems[i].blockInfo.x;
        float halfScale = scale * 0.5;

        ivec4 info = texelFetch(u_BlockAABBInfo, blockId);
        int aabbCount = info.y;
        int aabbOffset = info.x;

