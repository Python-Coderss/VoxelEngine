                        vec3 halfAABB = (scaledMax - scaledMin) * 0.5;
                        vec3 localP = (hp - centerAABB) / max(halfAABB, vec3(0.0001));
                        vec3 la = abs(localP);
                        if (la.x >= la.y && la.x >= la.z) hitN = vec3(sign(localP.x), 0, 0);
                        else if (la.y >= la.z) hitN = vec3(0, sign(localP.y), 0);
                        else hitN = vec3(0, 0, sign(localP.z));
                        hit = true;
                    }
                }
            }
        } else {
            // No AABBs (e.g. water): treat as full block at item scale
            vec3 halfSize = vec3(halfScale);
            float tn, tf;
            if (intersectAABB(ro, rd, pos - halfSize, pos + halfSize, tn, tf)) {
                float hitT = tn > 0.0 ? tn : tf;
                if (hitT < minT) {
                    minT = hitT;
                    vec3 localP = (ro + rd * hitT - pos) / max(halfScale, 0.0001);
                    vec3 la = abs(localP);
                    if (la.x >= la.y && la.x >= la.z) hitN = vec3(sign(localP.x), 0, 0);
                    else if (la.y >= la.z) hitN = vec3(0, sign(localP.y), 0);
                    else hitN = vec3(0, 0, sign(localP.z));
                    hit = true;
                }
            }
        }

        if (hit && minT < resT) {
            resT = minT;
            resN = hitN;
            resCraftingIdx = i;
            isEnt = false;
        }
    }
    return resT < 1e20;
}

