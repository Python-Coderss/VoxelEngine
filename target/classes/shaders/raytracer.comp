#version 430 core

layout(local_size_x = 16, local_size_y = 16) in;
layout(rgba8, binding = 0) uniform image2D imgOutput;

layout(location = 0) uniform vec3 camPos;
layout(location = 1) uniform vec3 camForward;
layout(location = 2) uniform vec3 camRight;
layout(location = 3) uniform vec3 camUp;

layout(std430, binding = 1) buffer readonly restrict IndirectionTable {
    uint chunkSlots[];
};

layout(std430, binding = 2) buffer readonly restrict ChunkPool {
    uint voxelPool[];
};

layout(std430, binding = 5) buffer readonly restrict LightPool {
    uint lightPool[];
};

struct EntityPart {
    mat4 worldToLocal;
    int voxelOffset; // Offset into EntityVoxelPool
    int pad1, pad2, pad3;
};

layout(std430, binding = 3) buffer readonly restrict EntityParts {
    EntityPart parts[];
};

layout(std430, binding = 4) buffer readonly restrict EntityVoxelPool {
    uint entityVoxels[]; // Packed shorts as uints or just uints
};

uniform int numEntityParts;

const int CHUNK_SIZE = 16;
const int REGION_SIZE = 128;
const int WORLD_SIZE = 2048; // 128 * 16
const uint EMPTY = 0xFFFFFFFF;

const vec3 PALETTE[5] = vec3[](
    vec3(0.5, 0.7, 0.9), // Sky
    vec3(0.4, 0.4, 0.4), // Floor 1
    vec3(0.6, 0.3, 0.1), // Floor 2
    vec3(0.8, 0.2, 0.2), // Red
    vec3(0.2, 0.8, 0.2)  // Green
);

bool intersectAABB(vec3 ro, vec3 rd, vec3 boxMin, vec3 boxMax, out float tNear, out float tFar) {
    vec3 invDir = 1.0 / rd;
    vec3 t0 = (boxMin - ro) * invDir;
    vec3 t1 = (boxMax - ro) * invDir;
    vec3 tmin = min(t0, t1);
    vec3 tmax = max(t0, t1);
    tNear = max(max(tmin.x, tmin.y), tmin.z);
    tFar = min(min(tmax.x, tmax.y), tmax.z);
    return tNear <= tFar && tFar > 0.0;
}

bool ddaRaycast16x16x16(vec3 ro, vec3 rd, float tNear, float tFar, int voxelOffset, out float hitT, out int hitSide, out uint voxelType) {
    vec3 p = ro + rd * (max(0.0, tNear) + 0.0001);
    ivec3 mapPos = ivec3(floor(p));
    vec3 deltaDist = abs(1.0 / rd);
    ivec3 step = ivec3(sign(rd));
    vec3 sideDist = (step * (vec3(mapPos) - p) + (step * 0.5) + 0.5) * deltaDist;

    int currentHitSide = 0;
    int stepIdxX = step.x;
    int stepIdxY = step.y << 4;
    int stepIdxZ = step.z << 8;
    ivec3 lp = mapPos & 15;
    int localIdx = lp.x | (lp.y << 4) | (lp.z << 8);

    for (int i = 0; i < 48; i++) {
        if (any(lessThan(mapPos, ivec3(0))) || any(greaterThanEqual(mapPos, ivec3(16)))) break;
        
        uint voxel = entityVoxels[voxelOffset + localIdx];
        if (voxel > 0) {
            voxelType = voxel;
            hitSide = currentHitSide;
            if (hitSide == 0) hitT = sideDist.x - deltaDist.x;
            else if (hitSide == 1) hitT = sideDist.y - deltaDist.y;
            else hitT = sideDist.z - deltaDist.z;
            return true;
        }

        if (sideDist.x < sideDist.y) {
            if (sideDist.x < sideDist.z) {
                sideDist.x += deltaDist.x; mapPos.x += step.x; currentHitSide = 0; localIdx += stepIdxX;
            } else {
                sideDist.z += deltaDist.z; mapPos.z += step.z; currentHitSide = 2; localIdx += stepIdxZ;
            }
        } else {
            if (sideDist.y < sideDist.z) {
                sideDist.y += deltaDist.y; mapPos.y += step.y; currentHitSide = 1; localIdx += stepIdxY;
            } else {
                sideDist.z += deltaDist.z; mapPos.z += step.z; currentHitSide = 2; localIdx += stepIdxZ;
            }
        }
    }
    return false;
}

bool raycastEntityPart(int partIdx, vec3 worldRo, vec3 worldRd, inout float closestT, inout int hitSide, inout uint voxelType) {
    EntityPart part = parts[partIdx];
    vec4 localRo4 = part.worldToLocal * vec4(worldRo, 1.0);
    vec3 localRo = localRo4.xyz / localRo4.w;
    vec3 localRd = mat3(part.worldToLocal) * worldRd;
    float tScale = length(localRd);
    localRd /= tScale;

    float tNear, tFar;
    if (intersectAABB(localRo, localRd, vec3(0.0), vec3(16.0), tNear, tFar)) {
        float localHitT;
        int localHitSide;
        uint localVoxelType;
        if (ddaRaycast16x16x16(localRo, localRd, tNear, tFar, part.voxelOffset, localHitT, localHitSide, localVoxelType)) {
            float worldHitT = localHitT / tScale;
            if (worldHitT < closestT) {
                closestT = worldHitT;
                hitSide = localHitSide;
                voxelType = localVoxelType;
                return true;
            }
        }
    }
    return false;
}

vec3 sampleLight(ivec3 p) {
    if (any(lessThan(p, ivec3(0))) || any(greaterThanEqual(p, ivec3(WORLD_SIZE)))) return vec3(0.0);
    ivec3 chunkCoords = p >> 4;
    uint chunkIdx = chunkCoords.x | (chunkCoords.y << 7) | (chunkCoords.z << 14);
    uint slot = chunkSlots[chunkIdx];
    if (slot == EMPTY) return vec3(0.0);
    // Every voxel in a chunk has the same light, so we just sample the first one
    uint packedLight = lightPool[slot << 12];
    return vec3(
        float(packedLight & 0xF),
        float((packedLight >> 4) & 0xF),
        float((packedLight >> 8) & 0xF)
    ) / 15.0;
}

vec3 getInterpolatedLight(vec3 worldPos) {
    // Offset by half a chunk to interpolate between chunk centers
    vec3 p = (worldPos - 8.0) / 16.0;
    ivec3 i = ivec3(floor(p));
    vec3 f = fract(p);

    // Sample 8 chunk centers
    vec3 c000 = sampleLight(i << 4);
    vec3 c100 = sampleLight((i + ivec3(1,0,0)) << 4);
    vec3 c010 = sampleLight((i + ivec3(0,1,0)) << 4);
    vec3 c110 = sampleLight((i + ivec3(1,1,0)) << 4);
    vec3 c001 = sampleLight((i + ivec3(0,0,1)) << 4);
    vec3 c101 = sampleLight((i + ivec3(1,0,1)) << 4);
    vec3 c011 = sampleLight((i + ivec3(0,1,1)) << 4);
    vec3 c111 = sampleLight((i + ivec3(1,1,1)) << 4);

    vec3 c00 = mix(c000, c100, f.x);
    vec3 c01 = mix(c001, c101, f.x);
    vec3 c10 = mix(c010, c110, f.x);
    vec3 c11 = mix(c011, c111, f.x);

    vec3 c0 = mix(c00, c10, f.y);
    vec3 c1 = mix(c01, c11, f.y);

    return mix(c0, c1, f.z);
}

void main() {
    ivec2 pixelCoords = ivec2(gl_GlobalInvocationID.xy);
    ivec2 size = imageSize(imgOutput);
    if (pixelCoords.x >= size.x || pixelCoords.y >= size.y) return;

    vec2 uv = (vec2(pixelCoords) + 0.5) / vec2(size);
    vec2 ndc = uv * 2.0 - 1.0;
    float aspect = float(size.x) / float(size.y);
    vec3 rayDir = normalize(camForward + ndc.x * aspect * camRight + ndc.y * camUp);

    vec3 hitColor = PALETTE[0];
    float worldT = 1e9;
    int worldHitSide = 0;
    uint worldVoxelType = 0;
    bool worldHit = false;

    float tNear, tFar;
    if (intersectAABB(camPos, rayDir, vec3(0.0), vec3(float(WORLD_SIZE)), tNear, tFar)) {
        vec3 p = camPos + rayDir * (max(0.0, tNear) + 0.0001);
        ivec3 mapPos = ivec3(floor(p));
        vec3 deltaDist = abs(1.0 / rayDir);
        ivec3 step = ivec3(sign(rayDir));
        vec3 sideDist = (step * (vec3(mapPos) - p) + (step * 0.5) + 0.5) * deltaDist;

        int currentHitSide = 0;
        int stepIdxX = step.x;
        int stepIdxY = step.y << 4;
        int stepIdxZ = step.z << 8;

        for (int i = 0; i < 2048; i++) {
            if (any(greaterThanEqual(uvec3(mapPos), uvec3(WORLD_SIZE)))) break;

            ivec3 chunkCoords = mapPos >> 4;
            uint chunkIdx = chunkCoords.x | (chunkCoords.y << 7) | (chunkCoords.z << 14);
            uint slot = chunkSlots[chunkIdx];

            if (slot == EMPTY) {
                ivec3 localPos = mapPos & 15;
                vec3 distToExit;
                distToExit.x = (step.x > 0) ? float(16 - localPos.x) : float(localPos.x + 1);
                distToExit.y = (step.y > 0) ? float(16 - localPos.y) : float(localPos.y + 1);
                distToExit.z = (step.z > 0) ? float(16 - localPos.z) : float(localPos.z + 1);
                vec3 tToExit = sideDist + (distToExit - 1.0) * deltaDist;
                
                if (tToExit.x <= tToExit.y && tToExit.x <= tToExit.z) {
                    sideDist.x = tToExit.x + deltaDist.x; mapPos.x += step.x * int(distToExit.x); currentHitSide = 0;
                } else if (tToExit.y <= tToExit.x && tToExit.y <= tToExit.z) {
                    sideDist.y = tToExit.y + deltaDist.y; mapPos.y += step.y * int(distToExit.y); currentHitSide = 1;
                } else {
                    sideDist.z = tToExit.z + deltaDist.z; mapPos.z += step.z * int(distToExit.z); currentHitSide = 2;
                }
            } else {
                uint poolOffset = slot << 12;
                ivec3 lp = mapPos & 15;
                int localIdx = lp.x | (lp.y << 4) | (lp.z << 8);

                for (int j = 0; j < 64; j++) {
                    uint voxel = voxelPool[poolOffset + localIdx];
                    if (voxel > 0) {
                        worldVoxelType = voxel; worldHit = true; 
                        if (currentHitSide == 0) worldT = sideDist.x - deltaDist.x;
                        else if (currentHitSide == 1) worldT = sideDist.y - deltaDist.y;
                        else worldT = sideDist.z - deltaDist.z;
                        worldHitSide = currentHitSide;
                        break;
                    }

                    if (sideDist.x < sideDist.y) {
                        if (sideDist.x < sideDist.z) {
                            sideDist.x += deltaDist.x; mapPos.x += step.x; currentHitSide = 0; localIdx += stepIdxX;
                        } else {
                            sideDist.z += deltaDist.z; mapPos.z += step.z; currentHitSide = 2; localIdx += stepIdxZ;
                        }
                    } else {
                        if (sideDist.y < sideDist.z) {
                            sideDist.y += deltaDist.y; mapPos.y += step.y; currentHitSide = 1; localIdx += stepIdxY;
                        } else {
                            sideDist.z += deltaDist.z; mapPos.z += step.z; currentHitSide = 2; localIdx += stepIdxZ;
                        }
                    }
                    if ((mapPos >> 4) != chunkCoords) break;
                }
                if (worldHit) break;
            }
        }
    }

    float closestT = worldT;
    int finalHitSide = worldHitSide;
    uint finalVoxelType = worldVoxelType;
    bool entityHit = false;

    for (int i = 0; i < numEntityParts; i++) {
        if (raycastEntityPart(i, camPos, rayDir, closestT, finalHitSide, finalVoxelType)) {
            entityHit = true;
        }
    }

    if (worldHit || entityHit) {
        hitColor = PALETTE[clamp(finalVoxelType, 0, 4)];
        
        vec3 hitPos = camPos + rayDir * closestT;
        vec3 normal = vec3(0.0);
        if (finalHitSide == 0) normal = vec3(-sign(rayDir.x), 0.0, 0.0);
        else if (finalHitSide == 1) normal = vec3(0.0, -sign(rayDir.y), 0.0);
        else normal = vec3(0.0, 0.0, -sign(rayDir.z));
        
        // Use trilinear interpolation between chunk centers for smooth lighting
        vec3 light = getInterpolatedLight(hitPos + normal * 0.5);
        
        hitColor *= (light + 0.1);

        if (finalHitSide == 0) hitColor *= 0.8;
        if (finalHitSide == 2) hitColor *= 0.9;
    } else {
        // Sky with some vertical gradient and minimal ambient
        hitColor = mix(PALETTE[0] * 0.5, PALETTE[0], max(0.0, rayDir.y + 0.5));
    }

    imageStore(imgOutput, pixelCoords, vec4(hitColor, 1.0));
}
