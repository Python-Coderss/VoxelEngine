#version 430 core

/**
 * The Enhanced Raytracer Compute Shader.
 * Features: PBR-lite shading, GGX Specular, Fresnel, Deterministic Sharp Shadows, 
 * Advanced Atmosphere, and Improved Volumetric Scattering.
 */

layout(local_size_x = 16, local_size_y = 16) in;

layout(rgba8, binding = 0) uniform image2D imgOutput;

// Uniforms
layout(location = 0) uniform vec3 camPos;
layout(location = 1) uniform vec3 camForward;
layout(location = 2) uniform vec3 camRight;
layout(location = 3) uniform vec3 camUp;
layout(location = 4) uniform float u_Time;

// SSBOs
layout(std430, binding = 1) buffer readonly restrict IndirectionTable {
    uint chunkSlots[];
};

layout(std430, binding = 2) buffer readonly restrict ChunkPool {
    uint voxelPool[];
};

layout(std430, binding = 5) buffer readonly restrict LightPool {
    uint lightPool[];
};

// Samplers
uniform sampler2DArray u_BlockTextures;
uniform isamplerBuffer u_BlockData;
uniform samplerBuffer u_BlockAABBs;
uniform isamplerBuffer u_BlockAABBInfo;
uniform isamplerBuffer u_BlockAABBUVs;
uniform sampler2D u_BiomeMap;
uniform sampler2D u_GrassColormap;
uniform sampler2D u_FoliageColormap;

// Constants
const int CHUNK_SIZE = 16;
const int WORLD_SIZE = 2048;
const uint EMPTY = 0xFFFFFFFF;
const float DDA_EPS = 1e-5;
const float PI = 3.14159265359;

/**
 * Hash function for noise and jitter.
 */
uint hash(uint x) {
    x += (x << 10u);
    x ^= (x >> 6u);
    x += (x << 3u);
    x ^= (x >> 11u);
    x += (x << 15u);
    return x;
}

float floatHash(uint x) {
    return float(hash(x)) / 4294967295.0;
}

/**
 * Interleaved Gradient Noise for jittering.
 */
float interleavedGradientNoise(vec2 uv) {
    vec3 magic = vec3(0.06711056, 0.00583715, 52.9829189);
    return fract(magic.z * fract(dot(uv, magic.xy)));
}

/**
 * ACES Filmic Tonemapping.
 */
vec3 ACESFilm(vec3 x) {
    return clamp((x*(2.51*x + 0.03))/(x*(2.43*x + 0.59) + 0.14), 0.0, 1.0);
}

/**
 * Celestial directions.
 */
void GetCelestialDirections(float t, out vec3 sunDir, out vec3 moonDir) {
    float angle = t * 0.05;
    sunDir = normalize(vec3(sin(angle), cos(angle), cos(angle * 0.7)));
    moonDir = -sunDir;
}

/**
 * Realistic Celestial Light Colors.
 */
vec3 GetCelestialLight(vec3 dir, bool isSun) {
    float horizon = max(0.0, dir.y);
    if (isSun) {
        // Sun: warm at horizon, neutral white at zenith
        vec3 sunColor = mix(vec3(8.0, 2.0, 0.5), vec3(1.64, 1.47, 1.29) * 5.0, sqrt(horizon));
        return sunColor;
    } else {
        // Moon: cool blue-silver
        return vec3(0.15, 0.25, 0.6) * 1.8;
    }
}

/**
 * Advanced Sky Atmosphere model.
 */
vec3 GetSkyAtmosphere(vec3 rd, vec3 sunDir, vec3 moonDir) {
    float dayFactor = smoothstep(-0.15, 0.15, sunDir.y);
    float sunDot = max(0.0, dot(rd, sunDir));
    
    // Rayleigh-like gradient
    vec3 daySky = mix(vec3(0.05, 0.15, 0.5), vec3(0.4, 0.65, 1.0), sqrt(max(0.0, rd.y * 0.9 + 0.1)));
    vec3 nightSky = mix(vec3(0.002, 0.005, 0.02), vec3(0.01, 0.015, 0.04), sqrt(max(0.0, rd.y)));
    
    // Sunset/Sunrise
    float sunsetFactor = pow(1.0 - abs(rd.y - sunDir.y * 0.5), 8.0) * smoothstep(0.4, -0.4, sunDir.y);
    vec3 sunsetColor = vec3(1.0, 0.3, 0.05) * sunsetFactor * 1.5;
    sunsetColor += vec3(0.6, 0.1, 0.0) * pow(max(0.0, 1.0 - rd.y), 3.0) * sunsetFactor;
    
    vec3 sky = mix(nightSky, daySky, dayFactor);
    sky += sunsetColor;
    
    // Tight Mie scattering glow around sun
    float mie = pow(sunDot, 2000.0) * 0.5 + pow(sunDot, 200.0) * 0.1;
    sky += GetCelestialLight(sunDir, true) * mie * dayFactor * 0.2;
    
    // Horizon haze
    vec3 haze = mix(vec3(0.05, 0.05, 0.1), vec3(0.8, 0.85, 0.9), dayFactor);
    sky = mix(sky, haze, pow(1.0 - max(0.0, rd.y), 10.0) * 0.6);
    
    return sky;
}

/**
 * Sun and Moon rendering.
 */
vec3 GetCelestialDisks(vec3 rd, vec3 sunDir, vec3 moonDir) {
    float sunDot = dot(rd, sunDir);
    float moonDot = dot(rd, moonDir);
    
    vec3 color = vec3(0.0);
    
    // Sun
    if (sunDir.y > -0.1) {
        float sunDisk = smoothstep(0.9998, 0.9999, sunDot);
        float sunGlow = pow(max(0.0, sunDot), 5000.0) * 5.0 + pow(max(0.0, sunDot), 500.0) * 0.5;
        vec3 sunColor = GetCelestialLight(sunDir, true);
        color += sunDisk * sunColor * 100.0;
        color += sunGlow * sunColor * 2.0;
    }
    
    // Moon
    if (moonDir.y > -0.1) {
        float moonDisk = smoothstep(0.99985, 0.99995, moonDot);
        color += moonDisk * vec3(0.9, 0.95, 1.0) * 15.0;
        color += pow(max(0.0, moonDot), 1000.0) * vec3(0.2, 0.3, 0.5) * 0.3;
    }
    
    return color;
}

/**
 * AABB Intersection.
 */
bool intersectAABB(vec3 ro, vec3 rd, vec3 boxMin, vec3 boxMax, out float tNear, out float tFar) {
    vec3 invDir = 1.0 / rd;
    vec3 t0 = (boxMin - ro) * invDir;
    vec3 t1 = (boxMax - ro) * invDir;
    vec3 tmin = min(t0, t1);
    vec3 tmax = max(t0, t1);
    tNear = max(max(tmin.x, tmin.y), tmin.z);
    tFar = min(min(tmax.x, tmax.y), tmax.z);
    return tNear <= tFar && tFar > 0.0;
}

/**
 * DDA Step.
 */
int advanceDDA(inout ivec3 mapPos, inout vec3 sideDist, vec3 deltaDist, ivec3 step) {
    float minDist = min(sideDist.x, min(sideDist.y, sideDist.z));
    bvec3 crossed = lessThanEqual(abs(sideDist - vec3(minDist)), vec3(DDA_EPS));
    int side = crossed.x ? 0 : (crossed.y ? 1 : 2);
    if (crossed.x) { sideDist.x += deltaDist.x; mapPos.x += step.x; }
    if (crossed.y) { sideDist.y += deltaDist.y; mapPos.y += step.y; }
    if (crossed.z) { sideDist.z += deltaDist.z; mapPos.z += step.z; }
    return side;
}

/**
 * Skip empty chunks.
 */
int skipEmptyChunk(inout ivec3 mapPos, inout vec3 sideDist, vec3 deltaDist, ivec3 step) {
    ivec3 localPos = mapPos & 15;
    ivec3 cellsToExit = ivec3(
        step.x > 0 ? 16 - localPos.x : localPos.x + 1,
        step.y > 0 ? 16 - localPos.y : localPos.y + 1,
        step.z > 0 ? 16 - localPos.z : localPos.z + 1
    );
    vec3 tToExit = sideDist + vec3(cellsToExit - ivec3(1)) * deltaDist;
    float minExit = min(tToExit.x, min(tToExit.y, tToExit.z));
    bvec3 crossed = lessThanEqual(abs(tToExit - vec3(minExit)), vec3(DDA_EPS));
    int side = crossed.x ? 0 : (crossed.y ? 1 : 2);
    if (crossed.x) { sideDist.x = tToExit.x + deltaDist.x; mapPos.x += step.x * cellsToExit.x; }
    if (crossed.y) { sideDist.y = tToExit.y + deltaDist.y; mapPos.y += step.y * cellsToExit.y; }
    if (crossed.z) { sideDist.z = tToExit.z + deltaDist.z; mapPos.z += step.z * cellsToExit.z; }
    return side;
}

/**
 * Light Sampling.
 */
vec3 sampleLightFast(ivec3 p) {
    ivec3 cc = p >> 4;
    if (any(lessThan(cc, ivec3(0))) || any(greaterThanEqual(cc, ivec3(128)))) return vec3(0.015);
    uint slot = chunkSlots[cc.x | (cc.y << 7) | (cc.z << 14)];
    if (slot == EMPTY) return vec3(0.015);
    ivec3 lp = p & 15;
    uint packedLight = lightPool[(slot << 12) | (lp.x | (lp.y << 4) | (lp.z << 8))];
    return vec3(float(packedLight & 0xFF), float((packedLight >> 8) & 0xFF), float((packedLight >> 16) & 0xFF)) / 255.0;
}

/**
 * Trilinear smooth light.
 */
vec3 getSurfaceLight(vec3 p, vec3 normal) {
    vec3 samplePos = p + normal * 0.5;
    ivec3 i = ivec3(floor(samplePos - 0.5));
    vec3 f = fract(samplePos - 0.5);
    vec3 c000 = sampleLightFast(i + ivec3(0,0,0)); vec3 c100 = sampleLightFast(i + ivec3(1,0,0));
    vec3 c010 = sampleLightFast(i + ivec3(0,1,0)); vec3 c110 = sampleLightFast(i + ivec3(1,1,0));
    vec3 c001 = sampleLightFast(i + ivec3(0,0,1)); vec3 c101 = sampleLightFast(i + ivec3(1,0,1));
    vec3 c011 = sampleLightFast(i + ivec3(0,1,1)); vec3 c111 = sampleLightFast(i + ivec3(1,1,1));
    return mix(mix(mix(c000, c100, f.x), mix(c010, c110, f.x), f.y), mix(mix(c001, c101, f.x), mix(c011, c111, f.x), f.y), f.z);
}

/**
 * World Raytracing.
 */
bool traceWorld(vec3 ro, vec3 rd, bool stopAtTransparent, bool skipFirst, out float resT, out int resSide, out uint resVoxel, out int resAabbIdx) {
    float tNear, tFar;
    resAabbIdx = -1;
    if (!intersectAABB(ro, rd, vec3(0.0), vec3(WORLD_SIZE), tNear, tFar)) return false;
    float startT = max(0.0, tNear);
    vec3 p = ro + rd * startT;
    ivec3 mapPos = ivec3(floor(p));
    vec3 deltaDist = abs(1.0 / rd);
    ivec3 step = ivec3(sign(rd));
    vec3 sideDist = (step * (vec3(mapPos) - p) + (step * 0.5) + 0.5) * deltaDist;
    int side = 0;
    if (skipFirst) side = advanceDDA(mapPos, sideDist, deltaDist, step);
    for (int i = 0; i < 512; i++) {
        if (any(lessThan(mapPos, ivec3(0))) || any(greaterThanEqual(mapPos, ivec3(WORLD_SIZE)))) break;
        uint slot = chunkSlots[(mapPos.x >> 4) | ((mapPos.y >> 4) << 7) | ((mapPos.z >> 4) << 14)];
        if (slot == EMPTY) { side = skipEmptyChunk(mapPos, sideDist, deltaDist, step); }
        else {
            uint poolOffset = slot << 12;
            ivec3 chunkCoord = mapPos >> 4;
            for (int j = 0; j < 64; j++) {
                uint voxel = voxelPool[poolOffset + ((mapPos.x & 15) | ((mapPos.y & 15) << 4) | ((mapPos.z & 15) << 8))];
                if (voxel > 0) {
                    ivec4 d1 = texelFetch(u_BlockData, int(voxel) * 3 + 1);
                    if (((d1.w >> 9) & 1) == 1) {
                        resVoxel = voxel; resSide = side;
                        resT = (side == 0 ? sideDist.x - deltaDist.x : (side == 1 ? sideDist.y - deltaDist.y : sideDist.z - deltaDist.z)) + startT;
                        return true;
                    } else {
                        ivec4 info = texelFetch(u_BlockAABBInfo, int(voxel));
                        int aabbOffset = info.x;
                        for (int k = 0; k < info.y; k++) {
                            vec3 bMin = texelFetch(u_BlockAABBs, aabbOffset + k * 2).xyz + floor(vec3(mapPos));
                            vec3 bMax = texelFetch(u_BlockAABBs, aabbOffset + k * 2 + 1).xyz + floor(vec3(mapPos));
                            float tn, tf;
                            if (intersectAABB(ro, rd, bMin, bMax, tn, tf)) {
                                if (tn < min(sideDist.x, min(sideDist.y, sideDist.z)) + startT) {
                                    resVoxel = voxel; resT = tn; resAabbIdx = (aabbOffset / 2) + k;
                                    vec3 hp = ro + rd * tn; vec3 center = (bMin + bMax) * 0.5; vec3 size = (bMax - bMin) * 0.5;
                                    vec3 localP = abs((hp - center) / size);
                                    if (localP.x > localP.y && localP.x > localP.z) resSide = 0; else if (localP.y > localP.z) resSide = 1; else resSide = 2;
                                    return true;
                                }
                            }
                        }
                    }
                }
                side = advanceDDA(mapPos, sideDist, deltaDist, step);
                if (any(notEqual(mapPos >> 4, chunkCoord))) break;
            }
        }
        if (min(sideDist.x, min(sideDist.y, sideDist.z)) + startT > tFar) break;
    }
    return false;
}

/**
 * Deterministic Shadow Tracing with empty chunk skipping.
 */
float traceShadow(vec3 ro, vec3 rd, float maxDist) {
    float tNear, tFar;
    if (!intersectAABB(ro, rd, vec3(0.0), vec3(WORLD_SIZE), tNear, tFar)) return 1.0;
    float startT = max(0.0, tNear);
    vec3 p = ro + rd * (startT + 0.02);
    ivec3 mapPos = ivec3(floor(p));
    vec3 deltaDist = abs(1.0 / rd);
    ivec3 step = ivec3(sign(rd));
    vec3 sideDist = (step * (vec3(mapPos) - p) + (step * 0.5) + 0.5) * deltaDist;
    for (int i = 0; i < 160; i++) {
        if (any(lessThan(mapPos, ivec3(0))) || any(greaterThanEqual(mapPos, ivec3(WORLD_SIZE)))) break;
        if (min(sideDist.x, min(sideDist.y, sideDist.z)) > maxDist) break;
        uint slot = chunkSlots[(mapPos.x >> 4) | ((mapPos.y >> 4) << 7) | ((mapPos.z >> 4) << 14)];
        if (slot == EMPTY) {
            skipEmptyChunk(mapPos, sideDist, deltaDist, step);
        } else {
            uint voxel = voxelPool[(slot << 12) | ((mapPos.x & 15) | ((mapPos.y & 15) << 4) | ((mapPos.z & 15) << 8))];
            if (voxel > 0) {
                ivec4 d1 = texelFetch(u_BlockData, int(voxel) * 3 + 1);
                if (((d1.w >> 9) & 1) == 1 || d1.z < 128) return 0.0;
            }
            advanceDDA(mapPos, sideDist, deltaDist, step);
        }
    }
    return 1.0;
}

/**
 * PBR-lite BRDF (GGX).
 */
float D_GGX(float NoH, float roughness) {
    float a = roughness * roughness;
    float a2 = a * a;
    float d = (NoH * a2 - NoH) * NoH + 1.0;
    return a2 / (PI * d * d);
}

/**
 * Fresnel Schlick - Optimized.
 */
vec3 fresnelSchlick(float cosTheta, vec3 F0) {
    float x = clamp(1.0 - cosTheta, 0.0, 1.0);
    float x2 = x * x;
    float f = x2 * x2 * x;
    return F0 + (1.0 - F0) * f;
}


vec3 calculateVolumetric(
    vec3 ro,
    vec3 rd,
    float maxDist,
    float jitter,
    vec3 sunDir,
    vec3 moonDir
) {
    float dist = min(maxDist, 160.0);
    float stepLen = dist * 0.5;

    vec3 scattering = vec3(0.0);

    // -------------------------------------------------
    // SUN
    // -------------------------------------------------
    if (sunDir.y > -0.15) {

        vec3 sunL = GetCelestialLight(sunDir, true);

        float cosSun = dot(rd, sunDir);

        // Faster than pow(x, 1.5)
        float d = 1.36 - 1.2 * cosSun;
        float phaseSun = 0.64 / (4.0 * PI * sqrt(d * d * d));

        // Step 0
        float t0 = (0.0 + jitter) * stepLen;
        vec3 p0 = ro + rd * t0;

        // Step 1
        float t1 = (1.0 + jitter) * stepLen;
        vec3 p1 = ro + rd * t1;

        scattering += sunL * traceShadow(p0, sunDir, 100.0) * phaseSun;
        scattering += sunL * traceShadow(p1, sunDir, 100.0) * phaseSun;
    }

    // -------------------------------------------------
    // MOON
    // -------------------------------------------------
    else if (moonDir.y > -0.15) {

        vec3 moonL = vec3(0.15, 0.25, 0.6) * 0.009;

        // Step 0
        float t0 = (0.0 + jitter) * stepLen;
        vec3 p0 = ro + rd * t0;

        // Step 1
        float t1 = (1.0 + jitter) * stepLen;
        vec3 p1 = ro + rd * t1;

        scattering += moonL * traceShadow(p0, moonDir, 80.0);
        scattering += moonL * traceShadow(p1, moonDir, 80.0);
    }

    return scattering * stepLen * 0.015;
}


void main() {
    ivec2 pixelCoords = ivec2(gl_GlobalInvocationID.xy);
    ivec2 size = imageSize(imgOutput);
    if (any(greaterThanEqual(pixelCoords, size))) return;

    float jitter = interleavedGradientNoise(vec2(pixelCoords));
    vec2 ndc = ((vec2(pixelCoords) + 0.5) / vec2(size)) * 2.0 - 1.0;
    vec3 rayRo = camPos;
    vec3 rayDir = normalize(camForward + ndc.x * (float(size.x)/size.y) * camRight + ndc.y * camUp);

    vec3 sunDir, moonDir;
    GetCelestialDirections(u_Time, sunDir, moonDir);

    vec3 finalColor = vec3(0.0);
    vec3 throughput = vec3(1.0);
    bool skip = false;
    float firstHitT = 200.0;

    for (int bounce = 0; bounce < 8; bounce++) {
        float t; int side; uint voxel; int aabbIdx;
        bool hit = traceWorld(rayRo, rayDir, true, skip, t, side, voxel, aabbIdx);
        if (bounce == 0) firstHitT = hit ? t : 200.0;

        if (!hit) {
            finalColor += throughput * (GetSkyAtmosphere(rayDir, sunDir, moonDir) + GetCelestialDisks(rayDir, sunDir, moonDir));
            break;
        }

        vec3 hitPos = rayRo + rayDir * t;
        vec3 normal = vec3(0.0);
        if (side == 0) normal.x = -sign(rayDir.x); else if (side == 1) normal.y = -sign(rayDir.y); else normal.z = -sign(rayDir.z);

        ivec4 d0 = texelFetch(u_BlockData, int(voxel) * 3);
        ivec4 d1 = texelFetch(u_BlockData, int(voxel) * 3 + 1);
        ivec4 d2 = texelFetch(u_BlockData, int(voxel) * 3 + 2);

        float trans = float(d1.z) / 255.0;
        float refl = float(d1.w & 0xFF) / 255.0;
        vec3 albedo = vec3(d2.rgb) / 255.0;
        int texIdx = (side == 0 ? (rayDir.x > 0 ? d1.x : d1.y) : (side == 1 ? (rayDir.y > 0 ? d0.x : d0.y) : (rayDir.z > 0 ? d0.z : d0.w)));

        if (texIdx >= 0) {
            vec2 uv = (side == 0 ? fract(hitPos.zy) : (side == 1 ? fract(hitPos.xz) : fract(hitPos.xy)));
            if (((d1.w >> 9) & 1) == 0 && aabbIdx != -1) {
                vec3 bMin = texelFetch(u_BlockAABBs, aabbIdx * 2).xyz;
                vec3 bMax = texelFetch(u_BlockAABBs, aabbIdx * 2 + 1).xyz;
                uv = (side == 0 ? (hitPos.zy - (floor(hitPos.zy) + bMin.zy)) / (bMax.zy - bMin.zy) : (side == 1 ? (hitPos.xz - (floor(hitPos.xz) + bMin.xz)) / (bMax.xz - bMin.xz) : (hitPos.xy - (floor(hitPos.xy) + bMin.xy)) / (bMax.xy - bMin.xy)));
            }
            vec4 tex = texture(u_BlockTextures, vec3(uv.x, 1.0 - uv.y, float(texIdx)));
            albedo *= tex.rgb;
            if (trans > 0.0 && tex.a < 0.1) { trans = 1.0; albedo = vec3(1.0); }
        }

        if (((d1.w >> 8) & 1) == 1) {
            vec2 b = texture(u_BiomeMap, hitPos.xz / 2048.0).rg;
            albedo *= texture(u_GrassColormap, vec2(1.0 - b.x, 1.0 - b.y)).rgb;
        }

        vec3 light = getSurfaceLight(hitPos, normal);
        
        // Direct Lighting - Optimized logic
        vec3 direct = vec3(0.0);
        if (sunDir.y > -0.1) {
            float sShadow = traceShadow(hitPos + normal * 0.02, sunDir, 1000.0);
            if (sShadow > 0.0) {
                float diffuse = max(0.0, dot(normal, sunDir));
                vec3 halfV = normalize(sunDir - rayDir);
                float spec = D_GGX(max(0.0, dot(normal, halfV)), mix(0.5, 0.05, refl)) * refl;
                direct += GetCelestialLight(sunDir, true) * (diffuse + spec) * sShadow;
            }
        }
        
        if (moonDir.y > -0.1) {
            float mShadow = traceShadow(hitPos + normal * 0.02, moonDir, 1000.0);
            if (mShadow > 0.0) {
                float diffuse = max(0.0, dot(normal, moonDir));
                direct += GetCelestialLight(moonDir, false) * diffuse * mShadow * 0.5;
            }
        }

        vec3 brdf = albedo * (light + direct + 0.03);
        if (side == 0) brdf *= 0.85; else if (side == 2) brdf *= 0.92;

        // Fresnel for reflections
        vec3 F0 = mix(vec3(0.04), albedo, refl);
        vec3 F = fresnelSchlick(max(0.0, dot(normal, -rayDir)), F0);
        float reflectionFactor = max(refl, F.r);

        // Fog
        float fog = 1.0 - exp(-t * 0.0007);
        brdf = mix(brdf, GetSkyAtmosphere(rayDir, sunDir, moonDir), fog);

        if (refl > 0.0 && trans < 1.0) {
            finalColor += throughput * brdf * (1.0 - reflectionFactor) * (1.0 - trans);
            throughput *= reflectionFactor;
            rayRo = hitPos + normal * 0.01; rayDir = reflect(rayDir, normal); skip = false;
        } else if (trans > 0.0) {
            finalColor += throughput * brdf * (1.0 - trans);
            throughput *= trans * albedo;
            rayRo = hitPos + rayDir * 0.01; skip = true;
        } else {
            finalColor += throughput * brdf;
            break;
        }
    }

    finalColor += calculateVolumetric(camPos, rayDir, firstHitT, jitter, sunDir, moonDir);
    
    // Lens: Vignette
    finalColor *= 1.0 - 0.4 * length(ndc);
    
    vec3 color = ACESFilm(finalColor);
    color = pow(color, vec3(1.0 / 2.2));
    imageStore(imgOutput, pixelCoords, vec4(color, 1.0));
}
